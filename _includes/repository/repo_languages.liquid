{% assign lang = site.active_lang | default: 'en-us' %}
{% assign github_locale = 'en' %}
{% case lang %}
  {% when 'fr-ca', 'fr' %}
    {% assign github_locale = 'fr' %}
  {% else %}
    {% assign github_locale = 'en' %}
{% endcase %}

  <!-- First Card - Language Distribution -->
  <div class="repo p-2 text-center">
    <a href="https://github.com/chloevoyer">
      <img
        class="repo-img-light w-200"
        alt="{{ include.username }} languages"
        src="https://github-readme-stats-nine-zeta-69.vercel.app/api/top-langs/?username={{ include.username }}&theme={{ site.repo_theme_light }}&locale={{ github_locale }}&show_icons=true&size_weight=0&count_weight=1&langs_count=5&layout=donut"
      >
      <img
        class="repo-img-dark w-200"
        alt="{{ include.username }} languages"
        src="https://github-readme-stats-nine-zeta-69.vercel.app/api/top-langs/?username={{ include.username }}&theme={{ site.repo_theme_dark }}&locale={{ github_locale }}&show_icons=true&size_weight=0&count_weight=1&langs_count=5&layout=donut"
      >
    </a>
  </div>

  <!-- Second Card - File Types -->
  <div class="repo p-2 text-center">
    <a href="https://github.com/chloevoyer">
      <picture>
        <img 
          class="repo-img-light w-200"
          src="/assets/img/generated/languages.svg#gh-light-mode-only"
          alt="{{ include.username }} file types"
        >
        <img 
          class="repo-img-dark w-200"
          src="/assets/img/generated/languages.svg#gh-dark-mode-only"
          alt="{{ include.username }} file types"
        >
      </picture>
    </a>
  </div>
