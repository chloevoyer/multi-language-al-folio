<div class="list-groups">
  {% for content in data[1] %}
    <div class="list-group col-md-6" title="{{ content.level }}">
      <table class="table-cv list-group-table">
        <tbody>
          <tr>
            {% if content.icon %}
              <td class="list-group-category-icon">
                <i class="{{ content.icon }}"></i>
              </td>
            {% else %}
              <td class="list-group-category-icon"></td>
            {% endif %}
            {% assign i = 1 %}
            {% for item in content.items %}
              {% assign i = i | plus: 1 %}
            {% endfor %}
            <td colspan="{{ i }}" class="list-group-category">{{ content.name }}</td>
          </tr>
          {% assign sorted_keywords = content.keywords | sort %}
          {% for item in sorted_keywords %}
            {% assign skill_key = item | downcase | replace: "/", "" | replace: " ", "" | replace: "(", "" | replace: ")", "" | replace: ",", "" %}
            {% assign logo = site.data.skill-logos[skill_key] %}
            <tr>
              <td></td>
              <td class="list-group-name">
                {% if logo %}
                  <span class="list-group-name-icon">
                    {% if logo.type == "image" %}
                      <img src="{{ site.baseurl }}/{{ logo.path }}" alt="{{ item }} icon" class="skill-custom-icon" style="filter: var(--global-icon-filter);" >
                    {% else %}
                      <i class="{{ logo.class }}"></i>
                    {% endif %}
                  </span>
                {% endif %}
                <b>{{ item }}</b>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endfor %}
</div>
