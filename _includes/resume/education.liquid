<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign education = data[1] | sort: 'startDate' | reverse %}
  {% for content in education %}
    <li class="list-group-item">
      <div class="row">
        <div class="col-xs-2 cl-sm-2 col-md-2 text-center date-column">
          {% if content.startDate and content.startDate != '' %}
            {% assign startDate = content.startDate | split: '-' | slice: 0, 1 | join: '.' %}
            {% assign endDate = content.endDate | split: '-' | slice: 0, 1 | join: '.' | default: '' %}
            {% assign date = startDate | append: '—' %}
            {% assign date = date | append: endDate %}
          {% else %}
            {% assign date = null %}
          {% endif %}
          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  {% if date %}
                    <span
                      class="badge font-weight-bold danger-color-dark text-lowercase align-middle"
                      style="min-width: 100px; vertical-align: middle"
                    >
                      {{ date }}
                    </span>
                  {% endif %}
                </td>
              </tr>
              {% if content.location %}
                <tr>
                  <td>
                    <p class="location">
                      <i class="fa-solid fa-location-dot iconlocation" style="padding-top: 5%; padding-right: 2%;"></i>
                      {{ content.location }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <i class="fa-solid fa-graduation-cap icongradcap" style="padding-bottom: 1%;"></i>
            <a href="{{ content.url }}">{{ content.studyType }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-weight: bolder">{{ content.area }}</h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">{{ content.institution }}</h6>
          <ul class="items" style="padding-left: 3.5em">
            {% for item in content.courses %}
              <li>
                <span class="item" style="font-size: 0.85rem">{{ item }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
