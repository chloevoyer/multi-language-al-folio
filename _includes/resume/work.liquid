<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign work = data[1] | sort: 'startDate' | reverse %}
  {% for content in work %}
    <li class="list-group-item">
      <div class="row">
        <div class="col-xs-2 cl-sm-2 col-md-2 text-center date-column">
          {% if content.startDate %}
            {% assign startDate_parts = content.startDate | split: '-' %}
            {% assign startYear = startDate_parts[0] %}
            {% if startDate_parts.size > 1 %}
              {% assign startMonth = startDate_parts[1] | append: '.' %}
            {% else %}
              {% assign startMonth = '' %}
            {% endif %}
            {% assign startDate = startMonth | append: startYear %}

            {% if content.endDate %}
              {% assign endDate_parts = content.endDate | split: '-' %}
              {% assign endYear = endDate_parts[0] %}
              {% if endDate_parts.size > 1 %}
                {% assign endMonth = endDate_parts[1] | append: '.' %}
              {% else %}
                {% assign endMonth = '' %}
              {% endif %}
              {% assign endDate = endMonth | append: endYear %}
            {% else %}
              {% assign endDate = site.data[site.active_lang].strings.cv.present %}
            {% endif %}

            {% assign date = startDate | append: ' — ' | append: endDate %}
          {% else %}
            {% assign date = '' %}
          {% endif %}
          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  <span class="badge font-weight-bold danger-color-dark text-lowercase align-middle" style="min-width: 100px; vertical-align: middle">
                    {{ date }}
                  </span>
                </td>
              </tr>
              {% if content.location %}
                <tr>
                  <td>
                    <p class="location">
                      <i class="fa-solid fa-location-dot iconlocation"></i>
                      {{ content.location }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <a href="{{ content.url }}">{{ content.position }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-weight: bolder">{{ content.name }}</h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">{{ content.summary }}</h6>
          <ul class="items" style="padding-left: 3.5em">
            {% for item in content.highlights %}
              <li>
                <span class="item" style="font-size: 0.85rem">{{ item }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
