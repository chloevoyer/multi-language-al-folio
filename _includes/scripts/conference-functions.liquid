{% capture conference_functions %}
  function filterConferences() {
    const yearFilter = document.getElementById('yearFilter').value;
    const fieldFilter = document.getElementById('fieldFilter').value;
    const modalityFilter = document.getElementById('modalityFilter').value;
    const locationFilter = document.getElementById('locationFilter').value;
    const statusFilter = document.getElementById('statusFilter').value;

    const today = new Date();
    const threeMonthsFromNow = new Date(today);
    threeMonthsFromNow.setMonth(today.getMonth() + 3);
    let visibleCount = 0;
    
    const cards = Array.from(document.querySelectorAll('.conference-card'));

    // Sort by start date
    cards.sort((a, b) => {
      return new Date(a.dataset.startDate) - new Date(b.dataset.startDate);
    });

    const container = document.querySelector('.conferences');
    cards.forEach(card => container.appendChild(card));

    cards.forEach(card => {
      const startDate = new Date(card.dataset.startDate);
      const endDate = card.dataset.endDate ? new Date(card.dataset.endDate) : null;
      const field = card.dataset.field;
      const modality = card.dataset.modality;
      const location = card.dataset.location;
      const status = card.dataset.status;

      let matchesYearFilter;
      if (yearFilter === 'upcoming') {
        matchesYearFilter = startDate >= today && startDate <= threeMonthsFromNow;
      } else {
        const eventYears = new Set();
        eventYears.add(startDate.getFullYear());
        if (endDate) {
          eventYears.add(endDate.getFullYear());
        }
        matchesYearFilter = eventYears.has(parseInt(yearFilter));
      }

      const matchesStatus = !statusFilter || statusFilter === 'all' || status === statusFilter;
      const matchesField = !fieldFilter || fieldFilter === 'all' || field === fieldFilter;
      const matchesModality = !modalityFilter || modalityFilter === 'all' || modality === modalityFilter;
      const matchesLocation = !locationFilter || locationFilter === 'all' || location === locationFilter;

      const shouldShow = matchesYearFilter && matchesField && matchesModality && 
                        matchesLocation && matchesStatus;
      card.style.display = shouldShow ? 'block' : 'none';

      if (shouldShow) visibleCount++;
    });

    const countElement = document.getElementById('visibleCount');
    if (countElement) {
      countElement.textContent = visibleCount;
    }

    const noResultsDiv = document.getElementById('noResults');
    if (noResultsDiv) {
      noResultsDiv.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  }

  // Initialize with upcoming events
  document.addEventListener('DOMContentLoaded', function() {
    const yearFilter = document.getElementById('yearFilter');
    yearFilter.value = "upcoming";
    filterConferences();
  });
{% endcapture %}
