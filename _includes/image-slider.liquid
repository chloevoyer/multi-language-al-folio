{% assign image_path = include.path | default: 'assets/img' %}
{% assign extension = include.extension | default: 'jpeg' %}
{% assign use_slides = include.slides | default: false %}
{% assign num_slides = include.count | default: 10 %}

<div class="image-slider {% if use_slides %}slide-mode{% else %}gallery-mode{% endif %}">
  <div class="slider-wrapper">
    {% if use_slides %}
      <div class="slider-container">
        {% for i in (1..num_slides) %}
          <div class="slide {% if forloop.first %}active{% endif %}">
            {% capture slide_path %}{{ image_path }}/slide-{{ i }}.{{ extension }}{% endcapture %}
            {% include figure.liquid loading="eager" path=slide_path class="img-fluid rounded z-depth-1" %}
          </div>
        {% endfor %}
        <button class="slider-nav prev" onclick="moveSlide(-1)">&#10094;</button>
        <button class="slider-nav next" onclick="moveSlide(1)">&#10095;</button>
      </div>
    {% else %}
      <button class="slider-nav prev" onclick="moveSlide(-1)">&#10094;</button>
      <div class="slider-container">
        {% assign images = site.static_files | where_exp: "file", "file.path contains image_path" %}
        {% for file in images %}
          {% if file.extname == extension or file.extname contains extension %}
            <div class="slide {% if forloop.first %}active{% endif %}">
              {% include figure.liquid loading="eager" path=file.path class="img-fluid rounded z-depth-1" %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <button class="slider-nav next" onclick="moveSlide(1)">&#10095;</button>
    {% endif %}
  </div>

  <div class="slider-dots">
    {% if use_slides %}
      {% for i in (1..num_slides) %}
        <span class="dot {% if forloop.first %}active{% endif %}" onclick="showSlide({{ forloop.index0 }})"></span>
      {% endfor %}
    {% else %}
      {% assign images = site.static_files | where_exp: "file", "file.path contains image_path" %}
      {% for file in images %}
        {% if file.extname == extension or file.extname contains extension %}
          <span class="dot {% if forloop.first %}active{% endif %}" onclick="showSlide({{ forloop.index0 }})"></span>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</div>

<style>
.image-slider {
  position: relative;
  max-width: 1000px;
  margin: auto;
}

.slider-wrapper {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Gallery mode specific wrapper */
.gallery-mode .slider-wrapper {
  margin: 0 -50px;
}

.slider-container {
  position: relative;
  width: 100%;
}

.slide {
  display: none;
}

.slide.active {
  display: block;
}

/* Gallery mode specific styles */
.gallery-mode .slide img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  object-position: center;
}

/* Presentation mode specific styles */
.slide-mode .slide img {
  width: 100%;
  height: auto;
  object-fit: contain;
}

.slider-nav {
  background: rgba(0, 0, 0, 0.5);
  color: white;
  padding: 8px 16px;
  border: none;
  cursor: pointer;
  border-radius: 50%;
  z-index: 2;
}

/* Gallery mode navigation */
.gallery-mode .slider-nav {
  position: relative;
}

/* Slide mode navigation */
.slide-mode .slider-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
}

.slide-mode .prev { left: 10px; }
.slide-mode .next { right: 10px; }

/* Responsive navigation for galleries */
@media (max-width: 768px) {
  .gallery-mode .slider-wrapper {
    margin: 0;
  }

  .gallery-mode .slider-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }

  .gallery-mode .prev { left: 10px; }
  .gallery-mode .next { right: 10px; }
}

.slider-dots {
  text-align: center;
  margin-top: 10px;
  padding-bottom: 25px;
}

.dot {
  height: 10px;
  width: 10px;
  margin: 0 4px;
  background-color: #bbb;
  border-radius: 50%;
  display: inline-block;
  cursor: pointer;
}

.dot.active {
  background-color: #717171;
}
</style>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  let slideInterval;

  function showSlide(n) {
    slides[currentSlide].classList.remove('active');
    dots[currentSlide].classList.remove('active');

    currentSlide = (n + slides.length) % slides.length;

    slides[currentSlide].classList.add('active');
    dots[currentSlide].classList.add('active');
  }

  function moveSlide(direction) {
    showSlide(currentSlide + direction);
  }

  const slider = document.querySelector('.image-slider');
  
  function pauseSlideShow() {
    if (slideInterval) {
      clearInterval(slideInterval);
    }
  }

  function resumeSlideShow() {
    if (!{{ use_slides }}) {
      pauseSlideShow();
      slideInterval = setInterval(() => moveSlide(1), 5000);
    }
  }

  slider.addEventListener('mouseenter', pauseSlideShow);
  slider.addEventListener('mouseleave', resumeSlideShow);

  if (!{{ use_slides }}) {
    resumeSlideShow();
  }
</script>