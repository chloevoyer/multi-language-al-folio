{% assign today_date = 'now' | date: '%Y-%m-%d' %}
{% assign conferences = site.data.conferences.conferences | sort: 'date' %}
{% include scripts/conference-functions.liquid %}

<div class="conferences-container">
  <div class="filters">
    <select id="yearFilter" onchange="filterConferences()">
      <option value="upcoming" selected>{{ site.data[site.active_lang].strings.list_psyc_conf.upcoming }}</option>
      {% assign all_years = site.data.conferences.conferences | map: 'date' | sort | reverse %}
      {% assign unique_years = '' | split: '' %}
      {% for date in all_years %}
        {% assign year = date | slice: 0, 4 %}
        {% unless unique_years contains year %}
          {% assign unique_years = unique_years | push: year %}
        {% endunless %}
      {% endfor %}

      {% for year in unique_years %}
        <option value="{{ year }}">{{ year }}</option>
      {% endfor %}
    </select>

    <select id="statusFilter" onchange="filterConferences()">
      <option value="" disabled selected>Status</option>
      <option value="all">All</option>
      <option value="confirmed">Confirmed</option>
      <option value="tba">TBA</option>
      </select>
      
    {% assign fields = site.data.conferences.conferences | map: 'field' | uniq | sort %}
    <select id="fieldFilter" onchange="filterConferences()">
      <option value="" disabled selected>Field</option>
      <option value="all">All</option>
      {% for field in fields %}
        {% if field != '' %}
          <option value="{{ field }}">{{ field }}</option>
        {% endif %}
      {% endfor %}
    </select>

    {% assign modalities = site.data.conferences.conferences | map: 'modality' | uniq | sort %}
    <select id="modalityFilter" onchange="filterConferences()">
      <option value="" disabled selected>Modality</option>
      <option value="all">All</option>
      {% for modality in modalities %}
        {% if modality != '' %}
          <option value="{{ modality }}">{{ modality }}</option>
        {% endif %}
      {% endfor %}
    </select>
    
    {% assign locations = site.data.conferences.conferences | map: 'local_abroad' | uniq | sort %}
    <select id="locationFilter" onchange="filterConferences()">
      <option value="" disabled selected>Location</option>
      <option value="all">All</option>
      {% for location in locations %}
        {% if location != '' %}
          <option value="{{ location }}">{{ location }}</option>
        {% endif %}
      {% endfor %}
    </select>
  </div>

  <div class="filters-summary">
    <div id="conferenceCount" class="conference-count">
      {{ site.data[site.active_lang].strings.list_psyc_conf.showing }}
      <span id="visibleCount">0</span> {{ site.data[site.active_lang].strings.list_psyc_conf.conferences }}
    </div>
  </div>

  <div class="conferences">
    {% assign conferences = site.data.conferences.conferences | sort: 'date' %}
    {% for conference in conferences %}
      {% assign conf_year = conference.date | date: '%Y' %}
      <div
        class="conference-card"
        data-year="{{ conference.date | slice: 0, 4 }}"
        data-date="{{ conference.date }}"
        data-field="{{ conference.field }}"
        data-modality="{{ conference.modality }}"
        data-location="{{ conference.local_abroad }}"
        data-status="{{ conference.status }}"
        {% if conference.date | slice: 0, 4 == "2024" and conference.date >= today_date %}
          style="display: block;"
        {% else %}
          style="display: none;"
        {% endif %}
      >
        <div class="conference-header">
          {% if conference.url != '' %}
            <h2>
              <a href="{{ conference.url }}" target="_blank" rel="noopener noreferrer" class="conference-name-link">
                {{ conference.name }}
              </a>
            </h2>
          {% else %}
            <h2>{{ conference.name }}</h2>
          {% endif %}
          {% if conference.acronym != '' %}
            <div class="acronym">{{ conference.acronym }}</div>
          {% endif %}
        </div>

        <div class="conference-info">
          <div class="date-info">
            <div class="event-date">
              <strong>{{ site.data[site.active_lang].strings.list_psyc_conf.event_date }}</strong>
              {{ conference.date | date: '%B %d, %Y' }}
            </div>

            {% if conference.submission_deadline %}
              <div class="deadline">
                <strong>{{ site.data[site.active_lang].strings.list_psyc_conf.deadline }}</strong>
                {{ conference.submission_deadline | date: '%B %d, %Y' }}
              </div>
            {% endif %}
          </div>

          <div class="location-info">
            <div class="location">
              <strong>{{ site.data[site.active_lang].strings.list_psyc_conf.location }}</strong> {{ conference.location }}
            </div>
          </div>

          {% if conference.theme != '' %}
            <div class="theme">
              <strong>{{ site.data[site.active_lang].strings.list_psyc_conf.theme }}</strong> {{ conference.theme }}
            </div>
          {% endif %}
        </div>

        <div class="conference-tags">
          <div class="tags-row">
            {% if conference.local_abroad != '' %}
              <div class="tag location-tag">
                {{ conference.local_abroad }}
              </div>
            {% endif %}

            {% if conference.modality != '' %}
              <div class="tag modality-tag">
                {{ conference.modality }}
              </div>
            {% endif %}

            {% if conference.field != '' %}
              <div class="tag field-tag">
                {{ conference.field }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div id="noResults" class="no-results" style="display: none;">
    {{ site.data[site.active_lang].strings.list_psyc_conf.noresults }}
  </div>
</div>

<script>
  {{ conference_functions }}

  // Initialize when document is ready
  document.addEventListener('DOMContentLoaded', function () {
    filterConferences();
    updateVisibleCount();
  });
</script>
