---
---
<div class="row">
  {% if site.enable_publication_thumbnails %}
    <div class="col col-sm-2 abbr">
      {%- if entry.abbr -%}
        {%- if site.data.venues[entry.abbr] -%}
          {% assign venue_style = null %}
          {% if site.data.venues[entry.abbr].color != blank %}
            {% assign venue_style = site.data.venues[entry.abbr].color | prepend: 'style="background-color:' | append: '"' %}
          {%- endif -%}
          <abbr
            class="badge rounded w-100"
            {% if venue_style %}
              {{ venue_style }}
            {% endif -%}
          >
            {% if site.data.venues[entry.abbr].url %}
              <a href="{{ site.data.venues[entry.abbr].url }}">{{ entry.abbr }}</a>
            {% else %}
              <div>{{- entry.abbr -}}</div>
            {% endif %}
          </abbr>
        {% else %}
          <abbr class="badge rounded w-100">{{ site.data[site.active_lang].strings.bibliography.abbrs[entry.abbr] | default: entry.abbr }}</abbr>
        {% endif %}
      {% endif %}
      {% if entry.preview %}
        {% if entry.preview contains '://' %}
          <img class="preview z-depth-1 rounded" src="{{ entry.preview }}">
        {% else %}
          {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
          {%
            include figure.liquid
            loading="eager"
            path=entry_path
            sizes = "200px"
            class="preview z-depth-1 rounded"
            zoomable=true
            alt=entry.preview
          %}
        {% endif %}
      {% endif %}
    </div>
  {% endif %}

  <!-- Entry bib key -->
  <div id="{{ entry.key }}" class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">
    <!-- Title -->
    <div class="title">
      {{- entry.title -}}
      {% if entry.spec_issue %}
        <br>[{{ site.data[site.active_lang].strings.bibliography.spec_issue }}]
      {% endif %}
      {% if entry.translated_title %}
        <br>
        <i>{{ entry.translated_title }}</i>
      {% endif %}
      {% if entry.chair and entry.symposium %}
        <br>
        <i>
          {{- site.data[site.active_lang].strings.bibliography.symposium_prefix | capitalize }}
          {{ entry.chair }} (
          {{- site.data[site.active_lang].strings.bibliography.chair_role -}}
          ), {{ entry.symposium -}}
        </i>
      {% elsif entry.symposium %}
        <br>
        <i>
          {{- site.data[site.active_lang].strings.bibliography.symposium_prefix | capitalize }}
          {{ entry.symposium -}}
        </i>
      {% endif %}
      {%- if entry.type contains 'internal' or entry.type contains 'oral' or entry.type contains 'poster' or entry.type contains 'symposium' -%}
        <span class="entry-type" style="font-family: 'Monaco', monospace !important; font-weight: bold;">
          <br>
          [
          {%- case entry.type -%}
            {%- when 'internal' -%}
              {{- site.data[site.active_lang].strings.bibliography.types.internal | downcase -}}
            {%- when 'oral' -%}
              {{- site.data[site.active_lang].strings.bibliography.types.oral | downcase -}}
            {%- when 'poster' -%}
              {{- site.data[site.active_lang].strings.bibliography.types.poster | downcase -}}
            {%- when 'symposium' -%}
              {{- site.data[site.active_lang].strings.bibliography.types.symposium | downcase -}}
          {%- endcase -%}
          ]
        </span>
      {%- endif -%}
    </div>

    <!-- Author -->
    <div class="author">
      {% assign author_array_size = entry.author_array | size %}
      {% assign author_array_limit = author_array_size %}
      {% if site.max_author_limit and author_array_size > site.max_author_limit %}
        {% assign author_array_limit = site.max_author_limit %}
      {% endif %}
      {%- for author in entry.author_array limit: author_array_limit -%}
        {% assign author_is_self = false %}
        {%- assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
        {%- assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' -%}

        {% comment %} Extract symbols and convert first name to initials {% endcomment %}
        {%- assign first_name_symbols = author.first | regex_replace: '[^*∗†‡§¶‖&^]', '' -%}
        {%- assign first_name_clean = author.first | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
        {%- assign name_parts = first_name_clean | split: ' ' -%}
        {%- assign initials = '' -%}

        {% comment %} Add symbols before the first initial {% endcomment %}
        {%- if first_name_symbols != '' -%}
          {%- assign initials = '<sup>' | append: first_name_symbols | append: '</sup>' -%}
        {%- endif -%}

        {% comment %} Add initials after the symbol {% endcomment %}
        {%- for name_part in name_parts -%}
          {%- assign initial = name_part | slice: 0 | append: '.' -%}
          {%- assign initials = initials | append: initial | append: ' ' -%}
        {%- endfor -%}

        {% if site.scholar.last_name contains author_last_name %}
          {% if site.scholar.first_name contains author.first %}
            {% assign author_is_self = true %}
          {% endif %}
        {%- endif -%}
        {% assign coauthor_url = null %}
        {%- assign clean_last_name = author_last_name | downcase | remove_accents -%}
        {% if site.data.coauthors[clean_last_name] %}
          {%- for coauthor in site.data.coauthors[clean_last_name] -%}
            {% if coauthor.firstname contains author.first %}
              {%- assign coauthor_url = coauthor.url -%}
              {% break %}
            {% endif %}
          {% endfor %}
        {%- endif -%}
        {%- if forloop.length > 1 -%}
          {% if forloop.first == false %},&nbsp;{% endif %}
          {%- if forloop.last and author_array_limit == author_array_size %}
            {{ site.data[site.active_lang].strings.bibliography.last_author_prefix }}&nbsp;
          {% endif -%}
        {% endif %}
        {%- if author_is_self -%}
          <em>
            {{- initials -}}
            {{ author_last_html -}}
          </em>
        {%- else -%}
          {%- if coauthor_url -%}
            <a href="{{ coauthor_url }}">
              {{- initials -}}
              {{ author_last_html -}}
            </a>
          {%- else -%}
            {{- initials -}}
            {{ author_last_html -}}
          {%- endif -%}
        {%- endif -%}
      {% endfor %}
      {%- assign more_authors = author_array_size | minus: author_array_limit -%}
      {%- if more_authors > 1 -%}
        {%- assign more_authors_hide = more_authors | append: ' ' | append: site.data[site.active_lang].strings.bibliography.more_authors.multiple -%}
      {%- else -%}
        {%- assign more_authors_hide = more_authors | append: ' ' | append: site.data[site.active_lang].strings.bibliography.more_authors.one -%}
      {%- endif -%}

      {% if more_authors > 0 %}
        {%- assign more_authors_show = '' %}
        {%- for author in entry.author_array offset: author_array_limit -%}
          {% comment %}Convert additional authors' names to initials with symbols{% endcomment %}
          {%- assign first_name_symbols = author.first | regex_replace: '[^*∗†‡§¶‖&^]', '' -%}
          {%- assign first_name_clean = author.first | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
          {%- assign name_parts = first_name_clean | split: ' ' -%}
          {%- assign initials = '' -%}
          {% comment %}Add symbols before the first initial for more authors{% endcomment %}
          {%- if first_name_symbols != '' -%}
            {%- assign initials = '<sup>' | append: first_name_symbols | append: '</sup>' -%}
          {%- endif -%}

          {%- for name_part in name_parts -%}
            {%- assign initial = name_part | slice: 0 | append: '.' -%}
            {%- assign initials = initials | append: initial | append: ' ' -%}
          {%- endfor -%}

          {% assign more_authors_show = more_authors_show | append: initials | append: author.last %}
          {% unless forloop.last %}
            {% assign more_authors_show = more_authors_show | append: ', ' %}
          {% endunless %}
        {%- endfor -%}
        , {{ site.data[site.active_lang].strings.bibliography.last_author_prefix }}
        <span
          class="more-authors"
          title="click to view {{ more_authors_hide }}"
          onclick="
              var element = $(this);
              element.attr('title', '');
              var more_authors_text = element.text() == '{{ more_authors_hide }}' ? '{{ more_authors_show }}' : '{{ more_authors_hide }}';
              var cursorPosition = 0;
              var textAdder = setInterval(function(){
                element.html(more_authors_text.substring(0, cursorPosition + 1));
                if (++cursorPosition == more_authors_text.length){
                  clearInterval(textAdder);
                }
            }, '{{ site.more_authors_animation_delay }}');
          "
        >
          {{- more_authors_hide -}}
        </span>
      {% endif %}
      {% if entry.annotation %}
        <i
          class="fa-solid fa-circle-info ml-1"
          data-toggle="popover"
          data-placement="top"
          data-html="true"
          data-content="{{ entry.annotation | escape }}"
        >
        </i>
      {% endif %}
    </div>

    <!-- Journal/Book title and date -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}

    <!-- Normalize entry types -->
    {% if entry.type == 'article' %}
      {% capture entrytype %}<em>{{ entry.journal }}</em><br>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>{{ site.data[site.active_lang].strings.bibliography.book_prefix | capitalize }} {{ entry.booktitle }}</em><br>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em><br>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}

    <!-- Date -->
    {% if entry.day %}
      {% capture entryday %}{{ " " }}{{ entry.day | replace: "-", "&ndash;" }}{% endcapture %}
    {% endif %}
    {% if entry.month %}
      {% capture entrymonth %}{{ " " }}{{ entry.month | capitalize }}{% endcapture %}
    {% endif %}
    {% if entry.year %}
      {% capture entryyear %}{{ " " }}{{ entry.year }}{% endcapture %}
    {% endif %}

    <!-- For conference info in periodical/additional info section -->
    {% if entry.conference %}
      {% assign entrytype_text = entrytype | strip_html | strip %}
      {% capture entrytype %}
        {{ entrytype }}
        {% if entrytype_text != "" %}, {% endif %}
        <em class="conference-name">{{ entry.conference }}</em>
        <br>
      {% endcapture %}
    {% endif %}

    {% comment %}
      {% if entry.location %}
        {% assign entrytype_text = entrytype | strip_html | strip %}
        {% capture entrytype %}{{ entrytype }}{% if entrytype_text != "" %}, {% endif %}{{ entry.location }}{% endcapture %}
      {% endif -%}
    {% endcomment %}
    {% if entry.additional_info %}
      {% capture entrytype %}{{ entrytype }}{{ entry.additional_info | markdownify | remove: '<p>' | remove: '</p>' }}{% endcapture %}
    {% endif %}
    {% capture hook_exists %}{% file_exists _includes/hook/bib.liquid %}{% endcapture %}
    {% if hook_exists == 'true' %}
      {% include hook/bib.liquid %}
    {% endif %}
    {% assign entrytype_text = entrytype | strip_html | strip %}
    {% capture periodical %}{{ entrytype }}{% if entrytype_text != "" and entryyear != "" %}{% endif %}{{ entrymonth }}{{ entryday }}{% if entryday and entryyear %}, {% endif %}{{ entryyear }}{% endcapture %}
    <div class="periodical">
      {{ periodical | strip }}
    </div>
    <div class="periodical">
      {{ entry.note | strip }}
    </div>

    <!-- Links/Buttons -->
    <div class="links">
      {% if entry.award %}
        <a class="award btn btn-sm z-depth-0" role="button">
          {%- if entry.award_name %}{{ entry.award_name }}{% else %}{{ site.data[site.active_lang].strings.bibliography.awarded }}{% endif -%}
        </a>
      {% endif %}
      {% if entry.highlights %}
        <a class="highlights btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.highlights }}</a>
      {% endif %}
      {% if entry.abstract %}
        <a class="abstract btn btn-sm z-depth-0" 
            role="button" 
            data-toggle="popover"
            data-trigger="hover"
            data-placement="top"
            data-content="abstract">
        {{ site.data[site.active_lang].strings.bibliography.abstract }}</a>
      {% endif %}
      {% if entry.tldr %}
        <a class="tldr btn btn-sm z-depth-0"
           role="button" 
           data-toggle="popover"
           data-trigger="hover"
           data-placement="top"
           data-content="long story short...">
          {{ site.data[site.active_lang].strings.bibliography.tldr }}
        </a>
      {% endif %}      
      {% if entry.arxiv %}
        <a href="{{ entry.arxiv }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.arxiv }}</a>
      {% endif %}
      {% if entry.bibtex_show %}
        <a class="bibtex btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.bibtex }}</a>
      {% endif %}
      {% if entry.html %}
        {% if entry.html contains '://' %}
          <a href="{{ entry.html }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.url }}</a>
          {% else %}
          <a href="{{ entry.html | prepend: '/assets/html/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">
          {{ site.data[site.active_lang].strings.bibliography.html }}
          </a>
        {% endif %}
      {% endif %}
      {% if entry.pdf %}
        {% if entry.pdf contains '://' %}
          <a href="{{ entry.pdf }}" class="btn btn-sm z-depth-0" role="button">
            {{ site.data[site.active_lang].strings.bibliography.pdf }}
            </a>
            {% else %}
            <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">
            {{ site.data[site.active_lang].strings.bibliography.pdf }}
            </a>
          {% endif %}
        {% endif %}
        {% if entry.supp %}
          {% if entry.supp contains '://' %}
            <a href="{{ entry.supp }}" 
                class="btn btn-sm z-depth-0" 
                role="button"
                data-toggle="popover"
                data-trigger="hover"
                data-placement="top"
                data-content="supplementary material"> 
              {{ site.data[site.active_lang].strings.bibliography.supp }}
            </a>
        {% else %}
          <a href="{{ entry.supp | prepend: '/assets/pdf/' | relative_url }}" 
              class="btn btn-sm z-depth-0" 
              role="button"
              data-toggle="popover"
              data-trigger="hover"
              data-placement="top"
              data-content="supplementary material">
            {{ site.data[site.active_lang].strings.bibliography.supp }}
          </a>
        {% endif %}
      {% endif %}
      {% if entry.video and site.enable_video_embedding %}
        <a class="video btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.video }}</a>
      {% elsif entry.video %}
        {% assign video_url = entry.video | strip %}
        {% if video_url contains '://' or video_url contains 'http' %}
          <a href="{{ video_url }}" class="btn btn-sm z-depth-0" role="button" target="_blank">
            {{- site.data[site.active_lang].strings.bibliography.video -}}
          </a>
        {% else %}
          <a href="{{ video_url | prepend: '/assets/video/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">
            {{- site.data[site.active_lang].strings.bibliography.video -}}
          </a>
        {% endif %}
      {% endif %}
      {% if entry.blog %}
        <a href="{{ entry.blog }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.blog }}</a>
      {% endif %}
      {% if entry.code %}
        <a href="{{ entry.code }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.code }}</a>
      {% endif %}
      {% if entry.poster %}
        {% if entry.poster contains '://' %}
          <a href="{{ entry.poster }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.poster }}</a>
        {% else %}
          <a href="{{ entry.poster | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">
            {{- site.data[site.active_lang].strings.bibliography.poster -}}
          </a>
        {% endif %}
      {% endif %}
      {% if entry.slides %}
        {% if entry.slides contains '://' %}
          <a href="{{ entry.slides }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.slides }}</a>
        {% else %}
          <a href="{{ entry.slides | prepend: '/assets/slides/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">
            {{- site.data[site.active_lang].strings.bibliography.slides -}}
          </a>
        {% endif %}
      {% endif %}
      {% if entry.website %}
        <a href="{{ entry.website }}" class="btn btn-sm z-depth-0" role="button">{{ site.data[site.active_lang].strings.bibliography.website }}</a>
      {% endif %}
    </div>
    {% if site.enable_publication_badges %}
      {% assign entry_has_altmetric_badge = false %}
      {% if entry.altmetric and entry.altmetric != 'false' %}
        {% assign entry_has_altmetric_badge = true %}
      {% endif %}

      {% assign entry_has_dimensions_badge = false %}
      {% if entry.dimensions and entry.dimensions != 'false' %}
        {% assign entry_has_dimensions_badge = true %}
      {% endif %}

      {% assign entry_has_google_scholar_badge = false %}
      {% if entry.google_scholar_id %}
        {% assign entry_has_google_scholar_badge = true %}
      {% endif %}

      {% assign entry_has_inspirehep_badge = false %}
      {% if entry.inspirehep_id %}
        {% assign entry_has_inspirehep_badge = true %}
      {% endif %}
      {% if entry_has_altmetric_badge or entry_has_dimensions_badge or entry_has_google_scholar_badge or entry_has_inspirehep_badge %}
        <div class="badges">
          {% if site.enable_publication_badges.altmetric and entry_has_altmetric_badge %}
            <span
              class="altmetric-embed"
              data-badge-type="2"
              data-badge-popover="right"
              {% if entry.altmetric != blank and entry.altmetric != 'true' %}
                data-altmetric-id="{{ entry.altmetric }}"
              {% elsif entry.arxiv %}
                data-arxiv-id="{{ entry.arxiv }}"
              {% elsif entry.eprint %}
                data-arxiv-id="{{ entry.eprint }}"
              {% elsif entry.doi %}
                data-doi="{{ entry.doi }}"
              {% elsif entry.pmid %}
                data-pmid="{{ entry.pmid }}"
              {% elsif entry.isbn %}
                data-isbn="{{ entry.isbn }}"
              {% endif %}
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.dimensions and entry_has_dimensions_badge %}
            <span
              class="__dimensions_badge_embed__"
              {% if entry.dimensions != blank and entry.dimensions != 'true' %}
                data-id="{{ entry.dimensions }}"
              {% elsif entry.doi %}
                data-doi="{{ entry.doi }}"
              {% else %}
                data-pmid="{{ entry.pmid }}"
              {% endif %}
              data-style="small_rectangle"
              data-legend="hover-right"
              style="margin-bottom: 3px;"
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.google_scholar and entry_has_google_scholar_badge %}
            <a
              href="https://scholar.google.ca/citations?view_op=view_citation&hl=en&user={{ site.scholar_userid }}&citation_for_view={{ site.scholar_userid }}:{{ entry.google_scholar_id }}"
              aria-label="Google Scholar link"
              role="button"
            >
              <img
                src="https://img.shields.io/badge/scholar-{% google_scholar_citations site.scholar_userid entry.google_scholar_id %}-4285F4?logo=googlescholar&labelColor=beige"
                alt="{% google_scholar_citations site.scholar_userid entry.google_scholar_id %} Google Scholar citations"
              >
            </a>
          {% endif %}
          {% if site.enable_publication_badges.inspirehep and entry_has_inspirehep_badge %}
            <a
              href="https://inspirehep.net/literature/{{ entry.inspirehep_id }}"
              aria-label="Inspirehep link"
              role="button"
            >
              <img
                src="https://img.shields.io/badge/inspire-{% inspirehep_citations entry.inspirehep_id %}-001628?logo=inspire&logoColor=001628&labelColor=beige"
                alt="{% inspirehep_citations entry.inspirehep_id %} InspireHEP citations"
              >
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    
    {% if entry.award %}
      <!-- Hidden Award block -->
      <div class="award hidden d-print-inline">
        <p>{{ entry.award | markdownify }}</p>
      </div>
    {% endif %}
        
    {% if entry.highlights %}
      <!-- Hidden Highlights block -->
      <div class="highlights hidden d-print-inline">
        <ul>
          {% assign sentences = entry.highlights | split: '. ' %}
          {% for sentence in sentences %}
            {% assign trimmed_sentence = sentence | strip %}
            {% if trimmed_sentence != '' %}
              <li>{{ trimmed_sentence | append: '.' | markdownify | remove: '<p>' | remove: '</p>' }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if entry.abstract %}
      <!-- Hidden abstract block -->
      <div class="abstract hidden">
        <p>
          {{
            entry.abstract
            | replace: 'Background:', '<b><i>Background:</i></b>'
            | replace: 'Objective:', '<b><i>Objective:</i></b>'
            | replace: 'Objectives:', '<b><i>Objectives:</i></b>'
            | replace: 'Aims:', '<b><i>Aims:</i></b>'
            | replace: 'Methods:', '<b><i>Methods:</i></b>'
            | replace: 'Results:', '<b><i>Results:</i></b>'
            | replace: 'Discussion:', '<b><i>Discussion:</i></b>'
            | replace: 'Conclusion:', '<b><i>Conclusion:</i></b>'
            | replace: 'Contexte :', '<b><i>Contexte :</i></b>'
            | replace: 'Objectifs :', '<b><i>Objectifs :</i></b>'
            | replace: 'Objectif :', '<b><i>Objectif :</i></b>'
            | replace: 'Méthodes :', '<b><i>Méthodes :</i></b>'
            | replace: 'Résultats :', '<b><i>Résultats :</i></b>'
            | replace: 'Discussion :', '<b><i>Discussion :</i></b>'
            | replace: 'Conclusion :', '<b><i>Conclusion :</i></b>'
          }}
        </p>
      </div>
    {% endif %}

    {% if entry.tldr %}
      <!-- Hidden tldr block -->
      <div class="tldr hidden">
        <p>{{ entry.tldr }}</p>
      </div>
    {% endif %}

    {% if entry.bibtex_show %}
      <!-- Hidden bibtex block -->
      <div class="bibtex hidden">
        {% highlight bibtex %}
        {{- entry.bibtex | hideCustomBibtex -}}
        {% endhighlight %}
      </div>
    {% endif %}

    {% if entry.video and site.enable_video_embedding %}
      <!-- Hidden video block -->
      <div class="video hidden">
        <div style="text-align: center">{% include video.liquid path=entry.video class="img-fluid rounded z-depth-1" controls=true %}</div>
      </div>
    {% endif %}
  </div>
</div>
