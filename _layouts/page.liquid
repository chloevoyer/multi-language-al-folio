---
layout: default
---

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}
    {% if page.icon %}
      <i class="fa fa-sm {{ page.icon }}"></i>
    {% elsif page.custom_icon %}
      <img src="{{ page.custom_icon }}" alt="Custom icon" class="page-custom-icon" style="filter: var(--global-icon-filter); height: 1em; vertical-align: middle;">
    {% endif %}
    </h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <div style="margin-top: 7.5rem;">
      <h2>{{ site.data[site.active_lang].strings.references }}</h2>
      <div class="publications">
        {% bibliography --cited_in_order %}
      </div>
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
